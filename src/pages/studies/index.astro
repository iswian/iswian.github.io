---
import BaseLayout from "@/layouts/BaseLayout.astro"
import SiteHeader from "@/components/site-header.astro"
import { Footer } from "@/components/footer"
import { StudiesList } from "@/components/studies-list"
import { getAllStudies } from "@/lib/studies"

const title = "专题 | 抹茶iswian的博客"
const description = "正在做的功课。每个专题聚合一组围绕同一问题的阅读、观看与笔记。"

const studies = await getAllStudies()
---

<BaseLayout {title} {description}>
  <div class="min-h-screen bg-background" data-pagefind-ignore>
    <SiteHeader />
    <main class="pt-20">
      <StudiesList client:idle studies={studies} />
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  /* Timeline always scrolls horizontally rather than being squashed by viewport */
  :global(.studies-timeline-scroll) {
    scrollbar-width: thin;
  }
  :global(.studies-timeline-scroll)::-webkit-scrollbar {
    height: 6px;
  }
  :global(.studies-timeline-scroll)::-webkit-scrollbar-thumb {
    background: color-mix(in oklab, var(--muted-foreground), transparent 70%);
    border-radius: 3px;
  }
</style>
